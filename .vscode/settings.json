{
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-build-dir",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-outdir=%DIR%/build",
        "-jobname=main",
        "%DOC%"
      ]
    },
    {
      "name": "copy-main-pdf",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$base = \"%DIR%\"; $pdfInBuild = Join-Path $base \"build/main.pdf\"; $pdfInRoot = Join-Path $base \"main.pdf\"; if (Test-Path $pdfInBuild) { Copy-Item -Path $pdfInBuild -Destination $pdfInRoot -Force; Remove-Item -Path $pdfInBuild -Force }"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk -> main.pdf (build aux files)",
      "tools": [
        "latexmk-build-dir",
        "copy-main-pdf"
      ]
    }
  ],
  "latex-workshop.latex.recipe.default": "latexmk -> main.pdf (build aux files)",
  "latex-workshop.latex.autoClean.run": "onBuilt",
  "latex-workshop.latex.clean.subfolder.enabled": true,
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.bcf",
    "*.blg",
    "*.idx",
    "*.ind",
    "*.lof",
    "*.lot",
    "*.out",
    "*.run.xml",
    "*.toc",
    "*.acn",
    "*.acr",
    "*.alg",
    "*.glg",
    "*.glo",
    "*.gls",
    "*.ist",
    "*.fls",
    "*.log",
    "*.fdb_latexmk",
    "*.synctex.gz"
  ]
}
